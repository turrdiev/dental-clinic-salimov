# ── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/dental_clinic"

# ── AUTH ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET="replace_this_with_a_secure_random_string_min_32_chars"

# ── SERVER ───────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000

# ── CORS — REQUIRED для продакшена ───────────────────────────────────────────
# Укажи точный URL деплоя, например: https://my-clinic.vercel.app
# Для локальной разработки: http://localhost:3000
APP_URL="http://localhost:3000"
